# SURI Environment Variables

# The Gemini API Key required for RAG lesson content generation
# Get yours from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_key_here

# FastAPI configurations (optional, defaults to suri.db)
DATABASE_URL=suri.db

# JWT Secret configuration (change in production!)
JWT_SECRET=dev-secret-change-in-production
